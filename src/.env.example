PORT=4001
NODE_ENV=development

# Database
DB_HOST=127.0.0.1
DB_NAME=saas_prontuario_production
DB_USER=
DB_PASS=
DB_DIALECT=mysql

# Auth (obrigatório — use valor forte em produção)
JWT_SECRET=
JWT_ACCESS_EXPIRES_IN=15m

# Stripe (billing SaaS)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=http://localhost:6263/app/billing?success=1
STRIPE_CANCEL_URL=http://localhost:6263/app/billing?canceled=1
STRIPE_CUSTOMER_PORTAL_RETURN_URL=http://localhost:6263/app/billing
